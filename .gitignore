*.pyc
*.py[cod]
*$py.class

# Native extensions / compiled artifacts
*.so
*.pyd
*.dll

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging/build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test, coverage, and type-check caches
.pytest_cache/
.mypy_cache/
.pyre/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# Lint/format caches
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Logs and runtime dumps
*.log

# IDE/editor files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Project-generated outputs
_4_DOE/results/
_4_DOE/population/

# Keep directory placeholders when needed
!_4_DOE/.gitkeep
