# Python bytecode/cache
__pycache__/
*.pyc
*.py[cod]
*$py.class

# Native extensions / compiled artifacts
*.so
*.pyd
*.dll

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging/build artifacts
Build/
dist/
*.egg-info/
.eggs/

# Test, coverage, and type-check caches
.pytest_cache/
.mypy_cache/
.pyre/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# Lint/format caches
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Logs and runtime dumps
*.log

# IDE/editor files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Project-generated outputs
_4_OptSim/results/
_4_OptSim/population/

# BobLib is tracked as a git submodule (gitlink mode 160000);
# keep this path visible even if future broad rules are added.
!_0_Utils/external/BobLib/

# Keep directory placeholders when needed
!DOE/.gitkeep
!DOE/results/.gitkeep
!DOE/population/.gitkeep

# Animations
*.gif
*.mp4
